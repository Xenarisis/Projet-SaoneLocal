{
    "info": {
        "_postman_id": "a1b2c3d4-e5f6-7a8b-9c0d-1e2f3a4b5c6d",
        "name": "Laravel API Tests",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Login",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('Connexion réussie (Status 200)', function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "var jsonData = pm.response.json();",
                            "",
                            "// Extraction intelligente du token selon les formats Laravel standards (Sanctum, Passport, custom JWT)",
                            "var token = jsonData.token || jsonData.access_token || (jsonData.data ? (jsonData.data.token || jsonData.data.access_token) : null);",
                            "",
                            "if (token) {",
                            "    pm.collectionVariables.set('jwt_token', token);",
                            "    console.log('Token JWT extrait avec succès !');",
                            "} else {",
                            "    pm.test('Erreur d\\'extraction du token', function () {",
                            "        pm.expect.fail('Impossible de trouver \"token\" ou \"access_token\" dans la réponse JSON. Adaptez le script de test si nécessaire.');",
                            "    });",
                            "}"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json",
                        "type": "text"
                    },
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n    \"email\": \"admin@admin.admin\",\n    \"password\": \"admin\"\n}"
                },
                "url": {
                    "raw": "http://localhost:8000/api/users/login",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "users",
                        "login"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "2. Get Users",
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "exec": [
                            "pm.test('Requête authentifiée réussie (Status 200)', function () {",
                            "    pm.response.to.have.status(200);",
                            "});",
                            "",
                            "pm.test('Affichage des utilisateurs dans la console Newman', function () {",
                            "    var jsonData = pm.response.json();",
                            "    // Ceci affichera le résultat dans la console lors de l'exécution",
                            "    console.log('--- RÉSULTAT API USERS ---');",
                            "    console.log(JSON.stringify(jsonData, null, 2));",
                            "    console.log('---------------------------');",
                            "    pm.expect(typeof jsonData).to.equal('object');",
                            "});"
                        ],
                        "type": "text/javascript"
                    }
                }
            ],
            "request": {
                "method": "GET",
                "header": [
                    {
                        "key": "Authorization",
                        "value": "Bearer {{jwt_token}}",
                        "type": "text"
                    },
                    {
                        "key": "Accept",
                        "value": "application/json",
                        "type": "text"
                    }
                ],
                "url": {
                    "raw": "http://localhost:8000/api/users",
                    "protocol": "http",
                    "host": [
                        "localhost"
                    ],
                    "port": "8000",
                    "path": [
                        "api",
                        "users"
                    ]
                }
            },
            "response": []
        }
    ],
    "variable": [
        {
            "key": "jwt_token",
            "value": "",
            "type": "string"
        }
    ]
}